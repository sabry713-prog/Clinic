# Database
DATABASE_URL=postgresql://app:app@localhost:5432/clinical_copilot

# Keycloak
OIDC_ISSUER_URL=http://localhost:8080/realms/dev
OIDC_CLIENT_ID=copilot-core
OIDC_CLIENT_SECRET=dev-secret-change-me
OIDC_REDIRECT_URI=http://localhost:4000/api/v1/auth/callback

# Object storage (MinIO in dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=clinical-copilot-dev

# Service ports
CORE_PORT=4000
NARRATIVE_GRPC_PORT=5001
QA_GRPC_PORT=5002
WEB_PORT=3000

# Internal service URLs (use 127.0.0.1, not localhost: Node >=17 resolves
# localhost to ::1 first, but the Python services bind IPv4 only)
QA_SERVICE_URL=http://127.0.0.1:5002
NARRATIVE_SERVICE_URL=http://127.0.0.1:5001

# Web app origin (used for the post-login redirect)
WEB_URL=http://localhost:3000

# Session
SESSION_SECRET=dev-session-secret-change-me-in-prod

# Foundation model (placeholder — set per chosen vendor)
FOUNDATION_MODEL_PROVIDER=stub
FOUNDATION_MODEL_API_KEY=
FOUNDATION_MODEL_ENDPOINT=

# On-prem model provider for QA + Narrative services (see docs/architecture/on-prem-model.md).
# Stage 1 is on-premise/in-Kingdom only — MODEL_ENDPOINT_URL must point at a LOCAL
# OpenAI-compatible server (vLLM/Ollama), never a public cloud API.
# Leave as "stub" until the on-prem GPU endpoint is provisioned.
QA_MODEL_PROVIDER=stub                 # stub | local
NARRATIVE_MODEL_PROVIDER=stub          # stub | local
MODEL_ENDPOINT_URL=http://localhost:8000/v1
MODEL_NAME=
MODEL_API_KEY=EMPTY
MODEL_TIMEOUT_S=60

# Dictation / transcription (on-prem STT — dictated audio is PHI, no cloud).
# Engine "stub" returns canned text; "faster_whisper" loads the on-prem model
# (install the transcription service's [whisper] extra on the GPU host).
TRANSCRIPTION_SERVICE_URL=http://127.0.0.1:5003
TRANSCRIPTION_ENGINE=stub              # stub | faster_whisper
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu                     # cuda on the GPU host
WHISPER_COMPUTE_TYPE=int8             # e.g. float16 on GPU
# Reformat: "light" (deterministic cleanup) or "llm" (faithful on-prem reformat,
# docs/prompts/reformat-prompt.md — polishes the clinician's OWN words, no new
# content). "llm" reuses MODEL_ENDPOINT_URL/MODEL_NAME above; falls back to light.
TRANSCRIPTION_REFORMAT=light           # light | llm

# Embedding model
EMBEDDING_MODEL_PROVIDER=stub
EMBEDDING_MODEL_ENDPOINT=

# NPHIES connector (claims/eligibility). "stub" returns canned payer
# responses so the claim workflow runs without CCHI onboarding; "live"
# requires NPHIES credentials + certificates (not yet implemented).
NPHIES_CONNECTOR=stub

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME is intentionally unset: each service ships its own distinct
# default (clinical-copilot-core / -narrative / -qa) for tracing.

# FHIR test endpoint (use HAPI public sandbox during early dev)
FHIR_BASE_URL=https://hapi.fhir.org/baseR4
FHIR_AUTH_MODE=none

# Node env
NODE_ENV=development

# Web public vars (Vite prefix)
VITE_API_BASE_URL=http://localhost:4000
