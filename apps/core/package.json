{
  "name": "@app/core",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "migrate:dev": "node-pg-migrate up -m migrations --envPath ../../.env",
    "migrate:create": "node-pg-migrate create -m migrations",
    "seed:dev": "ts-node src/seed/dev.ts",
    "seed:enrich": "ts-node src/seed/enrich.ts",
    "seed:symptoms": "ts-node src/seed/symptoms.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1066.0",
    "@clinical-copilot/audit": "workspace:*",
    "@clinical-copilot/fhir-client": "workspace:*",
    "@clinical-copilot/shared-types": "workspace:*",
    "@nestjs/common": "^10.3.8",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.8",
    "@nestjs/platform-express": "^10.3.8",
    "@nestjs/swagger": "^7.3.1",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.46.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.51.1",
    "@opentelemetry/sdk-node": "^0.51.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^17.4.2",
    "nestjs-pino": "^4.1.0",
    "openid-client": "^5.6.5",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-http": "^10.1.0",
    "pino-pretty": "^11.1.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/testing": "^10.3.8",
    "@types/cookie-parser": "^1.4.7",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "node-pg-migrate": "^7.4.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
